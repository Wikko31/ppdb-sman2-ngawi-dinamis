# Salin file ini menjadi .env untuk menjalankan konfigurasi lokal.
# File .env tidak dipush ke GitHub karena dapat berisi key rahasia.
PORT=3000
ADMIN_PASSWORD=adminppdb
SCHOOL_NAME=SMAN 2 NGAWI
REGISTRATION_YEAR=2026

# Kosongkan tiga variable ini jika ingin tetap memakai db/data.json lokal.
# Isi dari Supabase Project Settings > API untuk mode database online.
SUPABASE_URL=https://project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=isi_service_role_key_dari_supabase
SUPABASE_STORAGE_BUCKET=ppdb-documents
